# Spring backend taban URL'i. Public web ile AYNI değişken adı (BACKEND_URL).
# Panel tüm istekleri BFF üzerinden bu adrese iletir; tarayıcı backend'e
# doğrudan erişmez.
BACKEND_URL=http://localhost:8080

# Yerel geliştirmede panel varsayılan olarak 3000 portunda çalışır. Public web
# de 3000 kullanıyorsa çakışmayı önlemek için farklı bir port verin:
#   npm run dev -- -p 3100
